# ─── Full Stock — Variables de entorno ───────────────────────────────────────
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo .env a GitHub (ya está en .gitignore).

# MongoDB Atlas — Connection String
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@TU_CLUSTER.mongodb.net/fullstock?retryWrites=true&w=majority

# JWT — Clave secreta para firmar tokens (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-larga-y-segura

# Cloudinary — Subida de imágenes
# Consíguelos en: https://console.cloudinary.com → API Keys
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# CORS — Orígenes permitidos
# * → abierto (desarrollo)
# https://tu-dominio.com → un origen (producción)
# https://a.com,https://b.com → varios orígenes separados por coma
CORS_ORIGIN=*
